# ── Banco de dados (PostgreSQL) ────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tetusmanager
DB_USER=postgres
DB_PASSWORD=

# ── JWT ────────────────────────────────────────────────────────────────
# OBRIGATÓRIO: gere com `node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"`
JWT_SECRET=
JWT_EXPIRES_IN=8h

# ── Servidor ───────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:3000
